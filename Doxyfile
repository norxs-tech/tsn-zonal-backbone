# Doxyfile — norxs Deterministic TSN Zonal Backbone
# Run: doxygen Doxyfile
# Output: docs/html/index.html

#---------------------------------------------------------------------------
# Project metadata
#---------------------------------------------------------------------------
PROJECT_NAME           = "norxs Deterministic TSN Zonal Backbone"
PROJECT_NUMBER         = "v1.0.0"
PROJECT_BRIEF          = "AUTOSAR C++14 IEEE 802.1Qbv/CB/Qci/AE stack with Network Calculus latency verification — norxs Technology LLC"
PROJECT_LOGO           =
OUTPUT_DIRECTORY       = docs/doxygen
CREATE_SUBDIRS         = NO
OUTPUT_LANGUAGE        = English

#---------------------------------------------------------------------------
# Input
#---------------------------------------------------------------------------
INPUT                  = include/norxs/tsn \
                         src \
                         docs/architecture.md \
                         README.md
FILE_PATTERNS          = *.hpp *.cpp *.md
RECURSIVE              = YES
EXCLUDE                = tests/
USE_MDFILE_AS_MAINPAGE = README.md

#---------------------------------------------------------------------------
# Source browsing
#---------------------------------------------------------------------------
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

#---------------------------------------------------------------------------
# Extraction settings (AUTOSAR: document all, including private members for safety review)
#---------------------------------------------------------------------------
EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
JAVADOC_AUTOBRIEF      = NO
QT_AUTOBRIEF           = NO
MULTILINE_CPP_IS_BRIEF = NO
INHERIT_DOCS           = YES
SEPARATE_MEMBER_PAGES  = NO

#---------------------------------------------------------------------------
# Preprocessing
#---------------------------------------------------------------------------
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = YES
PREDEFINED             = DOXYGEN_RUNNING \
                         "TSN_RETURN_IF_ERR(x)="

#---------------------------------------------------------------------------
# Warnings
#---------------------------------------------------------------------------
WARNINGS               = YES
# Custom commands used by the norxs file-header convention.
# Registering them as aliases makes @project / @standards first-class
# Doxygen commands instead of "unknown command" warnings.
ALIASES               += "project=\par Project:^^"
ALIASES               += "standards=\par Standards:^^"

# Private members and per-\return docs are intentionally documented via
# trailing ///< comments and prose blocks; suppress the pedantic
# per-member warnings (the docs job reports remaining warnings as advisory).
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO

#---------------------------------------------------------------------------
# HTML output
#---------------------------------------------------------------------------
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html
HTML_TIMESTAMP         = YES
HTML_DYNAMIC_SECTIONS  = YES
GENERATE_TREEVIEW      = YES
TREEVIEW_WIDTH         = 280
SEARCHENGINE           = YES
SERVER_BASED_SEARCH    = NO

#---------------------------------------------------------------------------
# LaTeX / PDF output (for safety evidence packages)
#---------------------------------------------------------------------------
GENERATE_LATEX         = YES
LATEX_OUTPUT           = latex
LATEX_CMD_NAME         = pdflatex
COMPACT_LATEX          = NO
PAPER_TYPE             = a4
EXTRA_PACKAGES         =
LATEX_HEADER           =
LATEX_FOOTER           =
PDF_HYPERLINKS         = YES
USE_PDFLATEX           = YES

#---------------------------------------------------------------------------
# Diagrams (requires Graphviz / dot)
#---------------------------------------------------------------------------
HAVE_DOT               = YES
DOT_NUM_THREADS        = 2
CLASS_DIAGRAMS         = YES
CLASS_GRAPH            = YES
COLLABORATION_GRAPH    = YES
GROUP_GRAPHS           = YES
INCLUDE_GRAPH          = YES
INCLUDED_BY_GRAPH      = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
GRAPHICAL_HIERARCHY    = YES
DIRECTORY_GRAPH        = YES
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES
DOT_GRAPH_MAX_NODES    = 100

#---------------------------------------------------------------------------
# Cross-references
#---------------------------------------------------------------------------
GENERATE_TAGFILE       = docs/doxygen/norxs-tsn.tag
ALLEXTERNALS           = NO
EXTERNAL_GROUPS        = YES

#---------------------------------------------------------------------------
# Index
#---------------------------------------------------------------------------
ALPHABETICAL_INDEX     = YES
GENERATE_TODOLIST      = YES
GENERATE_TESTLIST      = YES
GENERATE_BUGLIST       = YES
GENERATE_DEPRECATEDLIST= YES

#---------------------------------------------------------------------------
# norxs footer note
#---------------------------------------------------------------------------
HTML_FOOTER            =
HTML_EXTRA_STYLESHEET  =
HTML_EXTRA_FILES       =
